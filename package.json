{
  "name": "Vibescape",
  "displayName": "Vibescape",
  "description": "Personalize your VS Code workspace with GIFs and images. Upload your favorite visuals and display them directly in the sidebar to create a workspace that feels uniquely yours.",
  "version": "1.0.0",
  "publisher": "sukanya-dg",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:vibescape.changeWallpaper",
    "onView:vibescapeView"
  ],
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "vibescape.changeWallpaper",
        "title": "Vibescape: Change Wallpaper"
      }
    ],
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "vibescapeView",
          "name": "✨ Vibescape"
        }
      ]
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "media"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sukanya-dg/Vibescape"
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.21",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
